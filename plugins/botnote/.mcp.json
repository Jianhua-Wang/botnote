{
  "mcpServers": {
    "botnote": {
      "command": "bash",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/scripts/run-mcp.sh"
      ],
      "cwd": ".",
      "env": {
        "BOTNOTE_URL": "${user_config.botnote_url}",
        "BOTNOTE_TOKEN": "${user_config.botnote_token}"
      }
    }
  }
}
